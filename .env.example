# ===== App =====
NODE_ENV=development
PORT=3000

# ===== Telegram =====
# Lay tu @BotFather
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
# polling cho local/dev, webhook cho production
TELEGRAM_UPDATES_MODE=polling
# URL public HTTPS cua app, vi du Railway default domain
PUBLIC_BASE_URL=https://cashbackbot-production.up.railway.app
# Optional: domain ngan rieng cho link redirect cashback va mo app Taobao/Tmall/1688.
# Neu bo trong, bot se dung PUBLIC_BASE_URL.
TAOBAO_OPEN_BASE_URL=
# Ngan path webhook kho doan duoc, vi du /telegram/webhook/chotdeal-prod
TELEGRAM_WEBHOOK_PATH=/telegram/webhook/chotdeal-prod-20260505
# Secret token Telegram gui trong header X-Telegram-Bot-Api-Secret-Token
TELEGRAM_WEBHOOK_SECRET_TOKEN=

# Telegram user ID cua admin, cach nhau bang dau phay neu co nhieu nguoi
# Lay ID bang cach nhan @userinfobot
TELEGRAM_ADMIN_IDS=

# Token bao ve web admin tai /api/admin/web
# Tao random dai 32+ ky tu va khong chia se cong khai.
ADMIN_WEB_TOKEN=

# ===== Zalo Bot Platform =====
# Token lay trong dashboard bot.zaloplatforms.com
ZALO_BOT_TOKEN=
# Secret Token 8-256 ky tu, paste cung mot gia tri vao dashboard Zalo.
ZALO_SECRET_TOKEN=
ZALO_BASE_URL=https://bot-api.zapps.me/bot

# ===== Database (Supabase) =====
# Connection pooling URL (port 6543) - dung cho runtime
DATABASE_URL="postgresql://postgres.xxxx:PASSWORD@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Direct URL (port 5432) - dung cho prisma migrate
DIRECT_URL="postgresql://postgres.xxxx:PASSWORD@aws-0-region.supabase.com:5432/postgres"

# ===== Accesstrade =====
# Pub ID cua ban tren Accesstrade
ACCESSTRADE_PUB_ID=your_pub_id_here
# API token, optional, chi dung khi muon tao short link qua API
ACCESSTRADE_API_TOKEN=
# Optional: campaign_id cho tung san.
# Bot chi mo cashback cho san nao co campaign_id verified.
# Shopee co default campaign da verify trong code; Lazada/Tiki can dien env truoc khi public.
# TikTok Shop CPS dung Product Feeds API v2 rieng, khong dung campaign_id/Product Link thuong.
ACCESSTRADE_CAMPAIGN_ID_SHOPEE=
ACCESSTRADE_CAMPAIGN_ID_LAZADA=
ACCESSTRADE_CAMPAIGN_ID_TIKI=
# Legacy/unused for TikTok Product Feeds v2; keep empty unless AT changes API again.
ACCESSTRADE_CAMPAIGN_ID_TIKTOK=
ACCESSTRADE_TIKTOK_CREATE_LINK_URL=https://api.accesstrade.vn/v2/tiktokshop_product_feeds/create_link
# Optional. Bot only verifies this when Accesstrade includes a `signature` field.
# Real AT postbacks currently include transaction_id/utm_source/reward, but no signature.
ACCESSTRADE_POSTBACK_SECRET=
# Override deeplink template neu AT cap pattern khac
# Placeholders: {pub_id}, {url}, {sub_id}, {merchant}

# ===== Alibo.vn (Taobao/Tmall/1688 - Trung Quoc) =====
# Account master alibo.vn cua bot. Moi link Taobao cua user se wrap qua tai khoan nay.
ALIBO_MASTER_REF=
# template|browser. Production Taobao/Tmall/1688 dung browser de tao link chiet khau realtime.
ALIBO_AUTOMATION_MODE=browser
ALIBO_LINK_TYPE=discount
# URL trang tao link chiet khau trong dashboard Alibo.
ALIBO_LINK_CREATOR_URL=
# Tao bang: npm run alibo:capture-session
ALIBO_STORAGE_STATE_BASE64=
# Local dev co the dung file session thay vi base64. Production Railway nen dung base64.
ALIBO_STORAGE_STATE_PATH=.secrets/alibo-storage-state.json
ALIBO_BROWSER_TIMEOUT_MS=45000
# Restart Chromium sau N request de giam rui ro memory leak khi chay lau.
ALIBO_BROWSER_RESTART_EVERY=100
# Template URL alibo. Verify bang cach login alibo, tao 1 link quang cao mau, paste pattern vao day.
# Placeholders: {master_ref}, {url}, {sub_id}, {item_id}, {merchant}
# Chi dung khi ALIBO_AUTOMATION_MODE khac browser.
ALIBO_LINK_TEMPLATE=
# % cashback chia cho user khi don tu alibo (alibo cat margin truoc, nen thuong < AT)
ALIBO_DEFAULT_USER_RATE=60
# Ty gia quy doi hoa hong Alibo tu CNY sang VND khi admin match don.
ALIBO_CNY_TO_VND_RATE=3600

# ===== Cashback config =====
# % hoa hong share lai cho user, vi du 70 = chia 70% cho user, giu 30%
USER_COMMISSION_RATE=70
# So tien toi thieu de payout (VND)
MIN_PAYOUT_AMOUNT=50000

# ===== Rate limit =====
# Toi da so message / window per user
RATE_LIMIT_MAX=10
# Window tinh bang ms
RATE_LIMIT_WINDOW_MS=30000
