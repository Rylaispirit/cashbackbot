// Cashback bot — Prisma schema
// DB: Supabase Postgres

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ===== User (multi-channel: Telegram / Zalo) =====
model User {
  id             String   @id @default(cuid())
  telegramId     BigInt?  @unique
  zaloUserId     String?  @unique
  username       String?
  firstName      String?
  lastName       String?
  // % cashback chia lại cho user (override default nếu cần)
  commissionRate Int? // null => dùng env USER_COMMISSION_RATE
  // Thông tin payout
  bankName       String?
  bankAccount    String?
  bankHolder     String?
  // Số dư đã được approved nhưng chưa payout (VND)
  balanceAvail   Int      @default(0)
  // Số dư đang pending (đơn chưa duyệt)
  balancePending Int      @default(0)
  // Tổng đã payout
  totalPaidOut   Int      @default(0)
  isBlocked      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  links             Link[]
  transactions      Transaction[]
  payouts           Payout[]
  dealSubscriptions DealSubscription[]

  @@map("users")
}

model DealSubscription {
  id        String   @id @default(cuid())
  userId    String
  merchant  String   @default("all")
  category  String   @default("all")
  isEnabled Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, merchant, category])
  @@index([isEnabled, merchant, category])
  @@index([userId])
  @@map("deal_subscriptions")
}

// ===== Link (mỗi lần user paste link) =====
model Link {
  id           String   @id @default(cuid())
  // sub_id duy nhất gắn vào affiliate URL — dùng để map postback về đúng user/link
  subId        String   @unique
  userId       String
  channel      String   @default("telegram") // telegram, zalo
  network      String   @default("accesstrade") // accesstrade, shopee_smartlink, ...
  merchant     String // shopee, lazada, tiki, ...
  originalUrl  String   @db.Text
  affiliateUrl String   @db.Text
  // Canonical URL after resolving short URL (e.tb.cn → item.taobao.com/item.htm?id=...)
  canonicalUrl String?  @db.Text
  // Numeric itemId extracted from canonicalUrl (indexed for auto-match)
  canonicalItemId String?
  // Product metadata captured from alibo's /coupon/ API response at link creation
  productTitle String?  @db.Text
  // Encoded id from alibo's response URL (uland.taobao.com/item/edetail?id=XXX) — Tier 3
  aliboEncodedId String?
  aliboMobileDeepLink String? @db.Text
  clickedAt    DateTime?
  createdAt    DateTime @default(now())

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]
  aliboOrders  AliboOrder[]

  @@index([userId])
  @@index([channel, createdAt])
  @@index([createdAt])
  @@index([canonicalItemId])
  @@index([aliboEncodedId])
  @@map("links")
}

// ===== Deal broadcast (admin gửi deal, user bấm nút mới tạo link riêng) =====
model Deal {
  id                  String   @id @default(cuid())
  title               String
  description         String?  @db.Text
  merchant            String
  originalUrl         String   @db.Text
  isActive            Boolean  @default(true)
  createdByTelegramId BigInt?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([isActive])
  @@index([createdAt])
  @@map("deals")
}

// ===== Transaction (1 đơn hàng từ postback) =====
// ===== Deal candidates (bot quet tu nguon deal, admin duyet moi gui user) =====
model DealCandidate {
  id                   String    @id @default(cuid())
  source               String    @default("accesstrade")
  externalId           String
  merchant             String
  title                String
  description          String?   @db.Text
  originalUrl          String    @db.Text
  imageUrl             String?   @db.Text
  sourceAffiliateUrl   String?   @db.Text
  startAt              DateTime?
  endAt                DateTime?
  status               String    @default("NEW")
  score                Int       @default(0)
  rawPayload           Json?
  dealId               String?
  reviewedByTelegramId BigInt?
  reviewedAt           DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@unique([source, externalId])
  @@index([status, createdAt])
  @@index([merchant])
  @@map("deal_candidates")
}

enum TransactionStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

model Transaction {
  id             String            @id @default(cuid())
  // External transaction ID (AT: transaction_id, alibo: manual `alibo_<orderId>`)
  // — đây là idempotency key thực sự, vì AT có thể gửi nhiều postback cho cùng orderId
  // (1 main commission + N brand bonus, mỗi cái transaction_id khác nhau).
  externalTxId   String?           @unique
  // Order ID hiển thị (NHIỀU transaction có thể share cùng orderId)
  orderId        String
  subId          String
  userId         String
  linkId         String?
  // Số tiền đơn hàng
  saleAmount     Int
  // Hoa hồng AT trả về (gross)
  grossCommission Int
  // Phần chia cho user
  userShare      Int
  // Phần bot giữ lại
  ownerShare     Int
  status         TransactionStatus @default(PENDING)
  rawPayload     Json
  approvedAt     DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  user       User        @relation(fields: [userId], references: [id])
  link       Link?       @relation(fields: [linkId], references: [id])
  aliboOrder AliboOrder?

  @@index([userId])
  @@index([status])
  @@index([subId])
  @@index([orderId])
  @@map("transactions")
}

// ===== Payout (chi trả cho user) =====
// ===== Alibo raw orders (Taobao/Tmall/1688) =====
model AliboOrder {
  id            String            @id @default(cuid())
  orderId       String
  lineKey       String            @unique
  platform      String?
  statusRaw     String
  status        TransactionStatus @default(PENDING)
  paidAt        DateTime?
  settledAt     DateTime?
  itemTitle     String?           @db.Text
  itemLink      String?           @db.Text
  itemImage     String?           @db.Text
  quantity      Int               @default(0)
  saleAmountCny Decimal?          @db.Decimal(12, 2)
  commissionCny Decimal?          @db.Decimal(12, 2)
  commissionVnd Int               @default(0)
  saleAmountVnd Int               @default(0)
  rawPayload    Json
  matchStatus   String            @default("UNMATCHED")
  matchedSubId  String?
  matchedLinkId String?
  transactionId String?           @unique
  matchedAt     DateTime?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  matchedLink Link?        @relation(fields: [matchedLinkId], references: [id], onDelete: SetNull)
  transaction Transaction? @relation(fields: [transactionId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@index([matchStatus, createdAt])
  @@index([status])
  @@index([paidAt])
  @@map("alibo_orders")
}

enum PayoutStatus {
  PENDING
  PROCESSING
  PAID
  FAILED
}

model Payout {
  id          String       @id @default(cuid())
  userId      String
  amount      Int
  status      PayoutStatus @default(PENDING)
  bankName    String?
  bankAccount String?
  bankHolder  String?
  note        String?
  paidAt      DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
  @@map("payouts")
}
